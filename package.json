        "git-revision-webpack-plugin": "^3.0.6",
        "html-loader": "^1.3.2",
        "html-webpack-plugin": "^4.5.0",
        "http-server": "^0.12.3",
        "mini-css-extract-plugin": "^0.9.0",
        "postcss-loader": "^3.0.0",
        "postcss-nested": "^4.2.1",
