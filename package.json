        "stylelint-config-recommended": "^3.0.0",
        "stylelint-webpack-plugin": "^2.1.1",
        "surge": "^0.21.7",
        "typescript": "^4.1.3",
        "webpack": "^4.43.0",
        "webpack-bundle-analyzer": "^3.9.0",
