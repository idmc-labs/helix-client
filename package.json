        "@togglecorp/toggle-ui": "^0.10.0-beta.4",
        "@turf/bbox": "^6.0.1",
        "@turf/bbox-polygon": "^6.0.1",
        "@turf/bearing": "^6.3.0",
        "@turf/combine": "^6.0.1",
        "@types/mapbox-gl": "^1.12.8",
        "@types/uuid": "^8.3.0",
        "apollo-link": "^1.2.14",
