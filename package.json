{
    "name": "helix-client",
    "version": "1.0.0",
    "description": "React client for Helix",
    "main": "src/index.tsx",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "sideEffects": [
        "src/Root/App/styles.css",
        "./node_modules/mapbox-gl/dist/mapbox-gl.css",
        "@togglecorp/toggle-ui/build/index.css"
    ],
    "scripts": {
        "start": "webpack-dev-server --mode development --config config/webpack.dev.js --env.NODE_ENV=development --history-api-fallback --color",
        "build:raw": "webpack --mode production --config config/webpack.prod.js --env.NODE_ENV=production",
        "build:unsafe": "mkdir -p generated && touch generated/types.tsx && yarn run build:raw",
        "build": "yarn run generate && yarn run typecheck && yarn run build:raw",
        "serve": "http-server ./build/ -p 3080 -g -c-1",
        "typecheck": "tsc",
        "lint": "eslint ./src",
        "generate": "env-cmd -f .env graphql-codegen --config codegen.yml",
        "deploy:surge": "test -d build && cp -f build/index.html build/200.html && surge --domain helix-client.surge.sh build/"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "1.20.0",
        "@graphql-codegen/introspection": "1.18.1",
        "@graphql-codegen/typescript": "1.20.0",
        "@graphql-codegen/typescript-operations": "1.17.13",
        "@types/apollo-upload-client": "^14.1.0",
        "@types/react": "^17.0.0",
        "@types/react-dom": "^17.0.0",
        "@types/react-router-dom": "^5.1.7",
        "@typescript-eslint/eslint-plugin": "^4.12.0",
        "@typescript-eslint/parser": "^4.12.0",
        "apollo": "^2.32.0",
        "body-parser": "^1.19.0",
        "cache-loader": "^4.1.0",
        "circular-dependency-plugin": "^5.2.2",
        "clean-webpack-plugin": "^3.0.0",
        "compression-webpack-plugin": "^4.0.0",
        "css-loader": "^3.6.0",
        "dotenv": "^8.2.0",
        "env-cmd": "^10.1.0",
        "esbuild-loader": "2.11.0",
        "eslint": "^7.17.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-airbnb-base": "^14.2.1",
        "eslint-import-resolver-webpack": "^0.13.0",
        "eslint-loader": "^4.0.2",
        "eslint-plugin-graphql": "^4.0.0",
        "eslint-plugin-import": "^2.22.1",
